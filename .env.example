# Telegram credentials
API_ID=1234567
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# Access control
OWNER_ID=123456789
SUDO_USERS=123456789,987654321
PROTECTED_USERS=

# Chatbot (Gemini)
CHATBOT_ENABLED=true
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
CHATBOT_TRIGGER_PREFIX=bot,
# Persona name is fixed in code as Sukoon.
CHATBOT_PERSONA_NAME=Sukoon
CHATBOT_HISTORY_SIZE=10
CHATBOT_IDLE_SECONDS=1800
CHATBOT_MAX_OUTPUT_TOKENS=180
CHATBOT_TEMPERATURE=0.8
CHATBOT_GROUP_COOLDOWN_SECONDS=1.5
CHATBOT_GROUP_REPLY_ALL=true
CHATBOT_RESPONSE_TIMEOUT_SECONDS=12
CHATBOT_ALLOW_SUDO=true

# Moderation performance and safety
WORKERS=16
MAX_CONCURRENT_OPERATIONS=25
OPERATION_DELAY_SECONDS=0.06
FLOOD_WAIT_THRESHOLD=30
MAX_BULK_ACTION_TARGETS=400
NUKE_DELETE_LIMIT=200

# Destructive command safeguards
REQUIRE_CHAT_ADMIN_FOR_SUDO_COMMANDS=true
COMMAND_CONFIRMATION_TTL_SECONDS=120
COMMAND_COOLDOWN_SECONDS=0
DELETE_COMMAND_MESSAGES=false
AUTO_LEAVE_AFTER_DESTRUCTIVE=false

# Cache and logs
USE_MEMBER_CACHE=true
MEMBER_CACHE_TTL_SECONDS=120
LOG_LEVEL=INFO
LOG_MAX_BYTES=1048576
LOG_RETENTION_FILES=5

